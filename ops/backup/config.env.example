# Garudar backup configuration — template.
#
# Copy to /etc/garudar-backup/config.env on the production VPS and edit values:
#     sudo install -m 0600 -o root -g root \
#         ops/backup/config.env.example /etc/garudar-backup/config.env
#     sudo nano /etc/garudar-backup/config.env
#
# This file is sourced by every script under ops/backup/. It must contain ONLY
# shell-style "KEY=value" lines (no spaces around =, no surprises).

# --- PostgreSQL --------------------------------------------------------------
# Name of the live database to back up.
DB_NAME=garudar_prod

# --- Paths -------------------------------------------------------------------
# Where local backup files live. Owned by root, mode 0700.
BACKUP_ROOT=/var/backups/garudar

# Absolute path to ops/backup/ inside the deployed git checkout.
# install.sh autodetects and rewrites this — leave the placeholder unless you
# know what you are doing.
SCRIPT_DIR=/home/REPLACE_ME/clear-garudar-backend/ops/backup

# Directory MinIO writes its objects to on the host. Default matches the
# docker-compose mount /home/documents_s3/:/data.
MINIO_DATA_DIR=/home/documents_s3/

# Host directory containing the infrastructure docker-compose.yml (the one
# that runs Nginx Proxy Manager, pgadmin, and the frontend nginx containers).
# Used by backup-configs.sh to grab NPM data + letsencrypt.
INFRA_DIR=/home/REPLACE_ME/infra

# --- Encryption --------------------------------------------------------------
# age recipient (PUBLIC key). The private key MUST be kept OFFLINE.
# Generated and written here by install.sh.
AGE_PUBLIC_KEY=age1REPLACE_ME

# Path where the age PRIVATE key is placed during restore operations.
# Default is fine. The key is normally absent on the server; copy it from
# offline storage just before restoring, then shred it afterwards.
AGE_PRIVATE_KEY_FILE=/etc/garudar-backup/age-private.key

# --- Alerts ------------------------------------------------------------------
ALERT_EMAIL=info@garudar.id

# SMTP relay used to send alerts. Re-uses the application's Gmail relay.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@garudar.id
SMTP_PASSWORD=REPLACE_ME    # Gmail app password (16 chars, no spaces)
MAIL_FROM=info@garudar.id

# --- Off-site (filled in once provider is chosen) ----------------------------
# OFFSITE_PROVIDER=b2          # or wasabi, s3, rclone, none
# OFFSITE_BUCKET=garudar-backups
# OFFSITE_KEY_ID=
# OFFSITE_KEY_SECRET=
